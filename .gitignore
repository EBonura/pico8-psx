# Rust build output (each game is its own workspace)
target/
**/target/

# Disc / EXE build artifacts
/build/
*.exe
*.bin
*.cue
*.toc

# itch.io release artifacts -- pushed to itch via butler, so the disc image in
# release/ must be tracked despite the *.bin / *.cue ignores above.
!/release/*.bin
!/release/*.cue
!/release/*.txt

# Reference audio captures (regenerable from the carts via tools/record_pico8_sfx.py)
audio-ref/
*.wav

# AI agent / editor scratch (kept local, never committed)
CLAUDE.md
AGENTS.md
.claude/
.codex/
.cursor/

# macOS
.DS_Store

# Python
__pycache__/
*.pyc
